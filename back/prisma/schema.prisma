generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Donation {
  id          Int       @id @default(autoincrement())
  name        String
  message     String?
  amount      Int
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  paidAt      DateTime?
  qrCode      String?
  accessToken String?   @unique
  slipImage   String?
  transRef    String?
  expiresAt   DateTime?
}

model Campaign {
  id              Int      @id @default(autoincrement())
  title           String
  goalAmount      Int
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  recentLimit     Int      @default(5)
  topDonatorLimit Int      @default(3)
}

model Setting {
  id               Int     @id @default(1)
  topDonatorsLimit Int     @default(3)
  refreshInterval  Int     @default(5000)
  soundEnabled     Boolean @default(true)
  ttsEnabled       Boolean @default(false)
  alertSound       String  @default("donation.mp3")
  alertVolume      Int     @default(100)
  overlayDuration  Int     @default(2)
  ttsVoice         String?
  promptpayNumber  String?
  minDonationAmount Int? // จำนวนโดเนทขั้นต่ำ
  maxDonationAmount Int? // จำนวนโดเนทสูงสุด
  overlayAnimation String  @default("fade") // fade | slide | zoom | bounce
  overlayImage     String? // path/URL รูปที่แสดงตอนโดเนทขึ้น
  readMessageEnabled Boolean @default(true) // อ่านข้อความผู้บริจาคหรือแค่ชื่อ+จำนวนเงิน
  monthlyGoalAmount    Int?
  monthlyGoalAutoReset Boolean @default(true) // true = นับเฉพาะเดือนปัจจุบัน, false = นับสะสมตลอดเวลา
  goalEffectEnabled    Boolean @default(true)
  // Top Donators
  topDonatorMode String    @default("all") // all | campaign | custom
  topDonatorFrom DateTime? // ใช้เมื่อ topDonatorMode = "custom"
  topDonatorTo   DateTime? // ใช้เมื่อ topDonatorMode = "custom"
}
